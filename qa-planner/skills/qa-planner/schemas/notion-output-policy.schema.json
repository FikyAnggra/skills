{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/qa-planner/notion-output-policy.schema.json",
  "title": "QA Planner Notion Output Policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["write_mode", "test_plan_page", "test_case_database", "fallback_behavior"],
  "properties": {
    "write_mode": {
      "type": "string",
      "enum": ["read_only", "page_only", "database_only", "full_sync"],
      "default": "full_sync"
    },
    "destination": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "workspace_id": { "type": "string" },
        "parent_page_id": { "type": "string" },
        "parent_page_url": { "type": "string" },
        "parent_database_id": { "type": "string" },
        "destination_notes": { "type": "string" }
      }
    },
    "test_plan_page": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "create_or_update_managed_page": { "type": "boolean", "default": true },
        "page_title_template": { "type": "string", "default": "QA Plan - <PROJECT> - <FEATURE> - <VERSION>" },
        "managed_section_marker": { "type": "string", "default": "qa-planner-managed" }
      }
    },
    "test_case_database": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "required": { "type": "boolean", "default": true },
        "create_or_update_managed_database": { "type": "boolean", "default": true },
        "database_title_template": { "type": "string", "default": "QA Test Cases - <PROJECT> - <FEATURE> - <VERSION>" },
        "required_properties": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["tc_id", "scenario", "summary", "test_type", "priority", "pre_conditions", "test_steps", "test_data", "expected_result", "actual_result", "test_case_status", "automation_status", "notes"]
        },
        "required_property_types": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "tc_id": { "type": "string", "const": "title" },
            "scenario": { "type": "string", "const": "rich_text" },
            "summary": { "type": "string", "const": "rich_text" },
            "test_type": { "type": "string", "const": "select" },
            "priority": { "type": "string", "const": "select" },
            "pre_conditions": { "type": "string", "const": "rich_text" },
            "test_steps": { "type": "string", "const": "rich_text" },
            "test_data": { "type": "string", "const": "rich_text" },
            "expected_result": { "type": "string", "const": "rich_text" },
            "actual_result": { "type": "string", "const": "rich_text" },
            "test_case_status": { "type": "string", "const": "select" },
            "automation_status": { "type": "string", "const": "select" },
            "notes": { "type": "string", "const": "rich_text" }
          },
          "default": {
            "tc_id": "title",
            "scenario": "rich_text",
            "summary": "rich_text",
            "test_type": "select",
            "priority": "select",
            "pre_conditions": "rich_text",
            "test_steps": "rich_text",
            "test_data": "rich_text",
            "expected_result": "rich_text",
            "actual_result": "rich_text",
            "test_case_status": "select",
            "automation_status": "select",
            "notes": "rich_text"
          }
        },
        "views": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["All Cases", "By Priority", "By Status", "Automation Candidates", "Manual Only"]
        },
        "batch_size": { "type": "integer", "minimum": 1, "default": 25 }
      }
    },
    "link_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "capture_page_url": { "type": "boolean", "default": true },
        "capture_database_url": { "type": "boolean", "default": true },
        "store_links_in_handoff_contracts": { "type": "boolean", "default": true },
        "share_links_to_active_platforms": { "type": "boolean", "default": true }
      }
    },
    "idempotency": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "search_existing_by_package_id": { "type": "boolean", "default": true },
        "update_existing_managed_artifacts": { "type": "boolean", "default": true },
        "managed_marker": { "type": "string", "default": "qa-planner-managed" }
      }
    },
    "fallback_behavior": {
      "type": "string",
      "enum": ["page_with_template_table", "render_local_json_markdown", "return_chat_artifacts"],
      "default": "page_with_template_table"
    },
    "custom_fields": {
      "type": "object",
      "additionalProperties": true,
      "default": {}
    }
  }
}
