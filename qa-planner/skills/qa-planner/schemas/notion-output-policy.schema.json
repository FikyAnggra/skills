{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/qa-planner/notion-output-policy.schema.json",
  "title": "QA Planner Notion Output Policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["write_mode", "test_plan_page", "test_case_database", "fallback_behavior"],
  "properties": {
    "write_mode": {
      "type": "string",
      "enum": ["read_only", "page_only", "database_only", "full_sync"],
      "default": "full_sync"
    },
    "destination": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "workspace_id": { "type": "string" },
        "parent_page_id": { "type": "string" },
        "parent_page_url": { "type": "string" },
        "parent_database_id": { "type": "string" },
        "destination_notes": { "type": "string" }
      }
    },
    "test_plan_page": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "create_or_update_managed_page": { "type": "boolean", "default": true },
        "page_title_template": { "type": "string", "default": "QA Plan - <PROJECT> - <FEATURE> - <VERSION>" },
        "managed_section_marker": { "type": "string", "default": "qa-planner-managed" }
      }
    },
    "test_case_database": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "required": { "type": "boolean", "default": true },
        "create_or_update_managed_database": { "type": "boolean", "default": true },
        "database_title_template": { "type": "string", "default": "QA Test Cases - <PROJECT> - <FEATURE> - <VERSION>" },
        "required_properties": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["TC ID", "Scenario", "Summary", "Test Type", "Priority", "Pre-Conditions", "Test Step", "Test Data", "Expected Result", "Actual Result", "Test Case Status", "Automation Status", "Notes"]
        },
        "required_property_types": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "TC ID": { "type": "string", "const": "title" },
            "Scenario": { "type": "string", "const": "rich_text" },
            "Summary": { "type": "string", "const": "rich_text" },
            "Test Type": { "type": "string", "const": "select" },
            "Priority": { "type": "string", "const": "select" },
            "Pre-Conditions": { "type": "string", "const": "rich_text" },
            "Test Step": { "type": "string", "const": "rich_text" },
            "Test Data": { "type": "string", "const": "rich_text" },
            "Expected Result": { "type": "string", "const": "rich_text" },
            "Actual Result": { "type": "string", "const": "rich_text" },
            "Test Case Status": { "type": "string", "const": "select" },
            "Automation Status": { "type": "string", "const": "select" },
            "Notes": { "type": "string", "const": "rich_text" }
          },
          "default": {
            "TC ID": "title",
            "Scenario": "rich_text",
            "Summary": "rich_text",
            "Test Type": "select",
            "Priority": "select",
            "Pre-Conditions": "rich_text",
            "Test Step": "rich_text",
            "Test Data": "rich_text",
            "Expected Result": "rich_text",
            "Actual Result": "rich_text",
            "Test Case Status": "select",
            "Automation Status": "select",
            "Notes": "rich_text"
          }
        },
        "logical_field_mapping": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "TC ID": { "type": "string", "const": "tc_id" },
            "Scenario": { "type": "string", "const": "scenario" },
            "Summary": { "type": "string", "const": "summary" },
            "Test Type": { "type": "string", "const": "test_type" },
            "Priority": { "type": "string", "const": "priority" },
            "Pre-Conditions": { "type": "string", "const": "pre_conditions" },
            "Test Step": { "type": "string", "const": "test_steps" },
            "Test Data": { "type": "string", "const": "test_data" },
            "Expected Result": { "type": "string", "const": "expected_result" },
            "Actual Result": { "type": "string", "const": "actual_result" },
            "Test Case Status": { "type": "string", "const": "test_case_status" },
            "Automation Status": { "type": "string", "const": "automation_status" },
            "Notes": { "type": "string", "const": "notes" }
          }
        },
        "views": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["All Cases", "By Priority", "By Status", "Automation Candidates", "Manual Only"]
        },
        "batch_size": { "type": "integer", "minimum": 1, "default": 25 }
      }
    },
    "link_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "capture_page_url": { "type": "boolean", "default": true },
        "capture_database_url": { "type": "boolean", "default": true },
        "store_links_in_handoff_contracts": { "type": "boolean", "default": true },
        "share_links_to_active_platforms": { "type": "boolean", "default": true }
      }
    },
    "idempotency": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "search_existing_by_package_id": { "type": "boolean", "default": true },
        "update_existing_managed_artifacts": { "type": "boolean", "default": true },
        "managed_marker": { "type": "string", "default": "qa-planner-managed" }
      }
    },
    "fallback_behavior": {
      "type": "string",
      "enum": ["page_with_template_table", "render_local_json_markdown", "return_chat_artifacts"],
      "default": "page_with_template_table"
    },
    "custom_fields": {
      "type": "object",
      "additionalProperties": true,
      "default": {}
    }
  }
}
