{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/qa-planner/plane-output-policy.schema.json",
  "title": "QA Planner Plane Output Policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["write_mode", "artifact_formats", "fallback_behavior", "transition_policy"],
  "properties": {
    "write_mode": {
      "type": "string",
      "enum": ["read_only", "comment_only", "attach_artifacts", "wiki_update", "full_sync"],
      "default": "full_sync"
    },
    "artifact_formats": {
      "type": "array",
      "items": { "type": "string", "enum": ["json", "markdown", "excel", "pdf", "word"] },
      "default": ["json", "markdown", "excel", "pdf", "word"]
    },
    "comment_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "update_existing_managed_comment": { "type": "boolean", "default": true },
        "include_status_transition_result": { "type": "boolean", "default": true },
        "comment_each_processed_sub_work_item": { "type": "boolean", "default": true },
        "sub_work_item_comment_marker_template": { "type": "string", "default": "qa-planner-managed <package_id> <readable_identifier>" }
      }
    },
    "attachment_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "upload_only_when_changed": { "type": "boolean", "default": true },
        "required_minimum_formats": {
          "type": "array",
          "items": { "type": "string", "enum": ["json", "markdown"] },
          "default": ["json", "markdown"]
        }
      }
    },
    "wiki_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "create_or_update_when_useful": { "type": "boolean", "default": true },
        "target": { "type": "string", "enum": ["project_page", "workspace_page"], "default": "project_page" },
        "read_existing_page_before_update": { "type": "boolean", "default": true },
        "update_existing_managed_page": { "type": "boolean", "default": true },
        "allowed_read_tools": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["retrieve_project_page", "retrieve_workspace_page", "get_project_page", "get_workspace_page"]
        },
        "allowed_update_tools": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["update_project_page", "update_workspace_page", "update_page"]
        },
        "html_body_required": { "type": "boolean", "default": true },
        "page_title_template": { "type": "string", "default": "QA Plan - <PROJECT>-<SEQ> - <feature title>" },
        "preserve_manual_sections": { "type": "boolean", "default": true },
        "managed_section_marker": { "type": "string", "default": "qa-planner-managed" },
        "fallback_when_update_unavailable": { "type": "string", "enum": ["create_versioned_page_and_link"], "default": "create_versioned_page_and_link" },
        "on_page_read_unavailable": { "type": "string", "enum": ["record_plane_page_read_gap"], "default": "record_plane_page_read_gap" },
        "on_page_update_unavailable": { "type": "string", "enum": ["record_plane_page_update_gap"], "default": "record_plane_page_update_gap" }
      }
    },
    "link_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "dedupe_existing_links": { "type": "boolean", "default": true },
        "allowed_link_types": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["qa_plan", "external_doc"]
        }
      }
    },
    "transition_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "move_timing", "on_missing_status_instruction", "on_target_status_not_found"],
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "target_status": { "type": "string" },
        "target_status_id": { "type": "string" },
        "resolve_target_with_list_states": { "type": "boolean", "default": true },
        "move_timing": { "type": "string", "enum": ["after_successful_plane_sync"] },
        "requires_user_confirmation": { "type": "boolean", "default": true },
        "on_missing_status_instruction": { "type": "string", "enum": ["ask_user_before_running"], "default": "ask_user_before_running" },
        "status_before": { "type": "string" },
        "status_after": { "type": "string" },
        "on_target_status_not_found": { "type": "string", "enum": ["skip_status_move"], "default": "skip_status_move" }
      }
    },
    "qa_state_workflow_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "default_eligible_state": { "type": "string", "default": "Todo Test" },
        "human_owned_backlog_state": { "type": "string", "default": "Backlog Test Human" },
        "analysis_state": { "type": "string", "default": "Analyze Test" },
        "update_state": { "type": "string", "default": "Update Test" },
        "review_state": { "type": "string", "default": "Need Review Test" },
        "ready_state": { "type": "string", "default": "Ready to Test" },
        "on_non_default_state": { "type": "string", "enum": ["ask_user_for_confirmation_after_state_read"], "default": "ask_user_for_confirmation_after_state_read" },
        "resolve_states_with_list_states": { "type": "boolean", "default": true }
      }
    },
    "sub_work_item_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "resolve_parent_before_sub_items": { "type": "boolean", "default": true },
        "dedupe_requested_ids": { "type": "boolean", "default": true },
        "apply_state_gate_per_item": { "type": "boolean", "default": true },
        "require_confirmation_for_each_non_default_state": { "type": "boolean", "default": true },
        "scenario_prefix_format": { "type": "string", "default": "<readable_identifier> - <scenario>" },
        "parent_level_artifacts": { "type": "boolean", "default": true },
        "comment_each_processed_item": { "type": "boolean", "default": true },
        "allow_create": { "type": "boolean", "default": true },
        "allow_update": { "type": "boolean", "default": true },
        "allow_state_change": { "type": "boolean", "default": true },
        "allow_delete_when_explicit": { "type": "boolean", "default": true },
        "delete_requires_named_item_ids": { "type": "boolean", "default": true },
        "on_missing_child_list_tool": { "type": "string", "enum": ["record_plane_sub_work_item_list_gap"], "default": "record_plane_sub_work_item_list_gap" },
        "on_missing_comment_tool": { "type": "string", "enum": ["record_plane_sub_work_item_comment_gap"], "default": "record_plane_sub_work_item_comment_gap" },
        "on_missing_delete_tool": { "type": "string", "enum": ["record_plane_sub_work_item_delete_gap"], "default": "record_plane_sub_work_item_delete_gap" }
      }
    },
    "fallback_behavior": {
      "type": "string",
      "enum": ["render_local_json_markdown", "return_chat_artifacts"],
      "default": "render_local_json_markdown"
    },
    "handoff_tracking_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "create_execution_work_items": { "type": "boolean", "default": false },
        "grouping": { "type": "string", "enum": ["module", "risk", "test_type", "environment", "cycle", "manual"], "default": "module" },
        "add_to_cycle": { "type": "boolean", "default": false },
        "target_cycle_id": { "type": "string" }
      }
    },
    "custom_fields": {
      "type": "object",
      "additionalProperties": true,
      "default": {}
    }
  }
}
