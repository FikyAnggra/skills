{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.qa/qa-automation/automation-status-update.schema.json",
  "title": "QA Automation Status Update",
  "type": "object",
  "additionalProperties": false,
  "required": ["update_id", "change_set_id", "items"],
  "properties": {
    "update_id": { "type": "string", "minLength": 1 },
    "change_set_id": { "type": "string", "minLength": 1 },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["tc_id", "previous_automation_status", "new_automation_status", "reason", "script_validation_outcome"],
        "properties": {
          "tc_id": { "type": "string", "minLength": 1 },
          "previous_automation_status": { "$ref": "#/$defs/automation_status" },
          "new_automation_status": { "$ref": "#/$defs/automation_status" },
          "automation_substatus": {
            "type": "string",
            "enum": ["script_created_unvalidated", "script_updated_unvalidated", "automation_implemented", "script_review_required", "script_review_ok", "validation_passed", "validation_failed", "blocked_by_gap", "skipped_manual_only"]
          },
          "reason": { "type": "string" },
          "script_path": { "type": "string" },
          "script_validation_outcome": { "type": "string", "enum": ["passed", "failed", "skipped", "blocked"] },
          "script_review_status": { "type": "string", "enum": ["pending", "OK", "NOK", "skipped"] },
          "validation_refs": { "type": "array", "items": { "type": "string" } },
          "notion_source_update": { "$ref": "#/$defs/source_update_outcome" },
          "plane_sync_refs": { "type": "array", "items": { "type": "string" } },
          "custom_fields": { "type": "object" }
        }
      }
    },
    "qa_executor_validation_request": { "type": "object" },
    "qa_reporter_automation_summary": { "type": "object" },
    "custom_fields": { "type": "object" }
  },
  "$defs": {
    "automation_status": {
      "type": "string",
      "enum": ["Manual Only", "To Be Automate", "Automation Implemented", "Already Automate"]
    },
    "source_update_outcome": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source_type": { "type": "string", "enum": ["notion_page", "notion_database_row", "notion_data_source_row", "plane_work_item", "none"] },
        "source_ref": { "type": "string" },
        "update_status": { "type": "string", "enum": ["not_started", "synced", "partial", "failed", "skipped"] },
        "sync_record_id": { "type": "string" },
        "gap": { "type": "string" },
        "custom_fields": { "type": "object" }
      }
    }
  }
}
