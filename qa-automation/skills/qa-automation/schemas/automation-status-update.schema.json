{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.qa/qa-automation/automation-status-update.schema.json",
  "title": "QA Automation Status Update",
  "type": "object",
  "additionalProperties": false,
  "required": ["update_id", "change_set_id", "items"],
  "properties": {
    "update_id": { "type": "string", "minLength": 1 },
    "change_set_id": { "type": "string", "minLength": 1 },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["tc_id", "previous_automation_status", "new_automation_status", "reason", "script_validation_outcome"],
        "properties": {
          "tc_id": { "type": "string", "minLength": 1 },
          "previous_automation_status": {
            "type": "string",
            "enum": ["To Be Automate", "Already Automate", "Manual Only"]
          },
          "new_automation_status": {
            "type": "string",
            "enum": ["To Be Automate", "Already Automate", "Manual Only"]
          },
          "automation_substatus": {
            "type": "string",
            "enum": ["script_created_validated", "script_created_unvalidated", "script_updated_validated", "validation_failed", "blocked_by_gap", "skipped_manual_only"]
          },
          "reason": { "type": "string" },
          "script_path": { "type": "string" },
          "script_validation_outcome": { "type": "string", "enum": ["passed", "failed", "skipped", "blocked"] },
          "validation_refs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "custom_fields": { "type": "object" }
        }
      }
    },
    "qa_executor_validation_request": { "type": "object" },
    "qa_reporter_automation_summary": { "type": "object" },
    "custom_fields": { "type": "object" }
  }
}
