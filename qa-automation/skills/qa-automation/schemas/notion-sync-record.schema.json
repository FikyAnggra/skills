{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.qa/qa-automation/notion-sync-record.schema.json",
  "title": "QA Automation Notion Sync Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sync_record_id",
    "change_set_id",
    "target_type",
    "action",
    "idempotency_key",
    "sync_status",
    "last_synced_at",
    "errors"
  ],
  "properties": {
    "sync_record_id": { "type": "string", "minLength": 1 },
    "change_set_id": { "type": "string", "minLength": 1 },
    "tc_id": { "type": ["string", "null"] },
    "source_page_id": { "type": ["string", "null"] },
    "source_database_id": { "type": ["string", "null"] },
    "source_data_source_id": { "type": ["string", "null"] },
    "target_type": {
      "type": "string",
      "enum": ["source_status", "source_row", "automation_page", "result_row", "comment", "schema", "delete"]
    },
    "target_id": { "type": ["string", "null"] },
    "action": {
      "type": "string",
      "enum": ["read", "create", "update", "skip", "comment", "link", "delete", "archive"]
    },
    "requires_confirmation": { "type": "boolean" },
    "confirmed": { "type": "boolean" },
    "idempotency_key": { "type": "string", "minLength": 1 },
    "content_hash": { "type": ["string", "null"] },
    "sync_status": {
      "type": "string",
      "enum": ["not_started", "synced", "partial", "failed", "skipped"]
    },
    "last_synced_at": { "type": ["string", "null"] },
    "errors": { "type": "array", "items": { "type": "string" } },
    "custom_fields": { "type": "object" }
  }
}
