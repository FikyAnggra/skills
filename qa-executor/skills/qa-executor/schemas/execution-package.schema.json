{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.qa/qa-executor/execution-package.schema.json",
  "title": "QA Executor Input Package",
  "type": "object",
  "additionalProperties": false,
  "required": ["package_id", "source_agent", "source_refs", "approval_state", "run_policy", "environment", "execution_scope", "test_cases"],
  "properties": {
    "package_id": { "type": "string", "minLength": 1 },
    "source_agent": {
      "type": "string",
      "enum": ["qa-planner", "human", "qa-executor", "plane", "notion", "external"]
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ref_type", "ref"],
        "properties": {
          "ref_type": {
            "type": "string",
            "enum": ["planning_state", "qa_executor_handoff", "manual_test_cases", "plane_work_item", "plane_comment", "plane_wiki", "plane_attachment", "plane_mcp_payload", "notion_page", "notion_database", "notion_data_source", "notion_comment", "notion_mcp_payload", "spreadsheet", "document", "json", "plain_text", "other"]
          },
          "ref": { "type": "string", "minLength": 1 },
          "summary": { "type": "string" }
        }
      }
    },
    "approval_state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["approved_by_planner", "approved_by_user", "draft_validation", "not_approved"]
        },
        "approved_by": { "type": "string" },
        "approved_at": { "type": ["string", "null"] },
        "notes": { "type": "string" }
      }
    },
    "run_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "selected_tc_ids", "parallel_allowed"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["initial_run", "full_regression", "failed_retest", "smoke", "targeted", "automation_validation"]
        },
        "selected_tc_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "priority_filter": {
          "type": "array",
          "items": { "type": "string", "enum": ["P0 - Critical", "P1 - High", "P2 - Medium", "P3 - Low"] }
        },
        "tag_filter": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "parallel_allowed": { "type": "boolean" },
        "notes": { "type": "string" }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "base_url": { "type": "string" },
        "build": { "type": "string" },
        "data_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "constraints": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "execution_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selected_count", "excluded_tc_ids"],
      "properties": {
        "selected_count": { "type": "integer", "minimum": 0 },
        "excluded_tc_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "selection_reason": { "type": "string" }
      }
    },
    "test_cases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/test_case" }
    },
    "plane_context": { "$ref": "#/$defs/plane_context" },
    "plane_write_policy": { "$ref": "#/$defs/plane_write_policy" },
    "plane_status_mapping": { "$ref": "#/$defs/plane_status_mapping" },
    "plane_state_workflow": { "$ref": "#/$defs/plane_state_workflow" },
    "notion_context": { "$ref": "#/$defs/notion_context" },
    "notion_write_policy": { "$ref": "#/$defs/notion_write_policy" },
    "notion_plane_bridge": { "$ref": "#/$defs/notion_plane_bridge" },
    "source_update_policy": { "$ref": "#/$defs/source_update_policy" },
    "report_output_policy": { "$ref": "#/$defs/report_output_policy" },
    "evidence_upload_policy": { "$ref": "#/$defs/evidence_upload_policy" },
    "custom_fields": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "plane_context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "workspace_id": { "type": "string" },
        "project_id": { "type": "string" },
        "project_identifier": { "type": "string" },
        "work_item_id": { "type": "string" },
        "readable_identifier": { "type": "string" },
        "url": { "type": "string" },
        "state": { "type": "string" },
        "assignees": {
          "type": "array",
          "items": { "type": "string" }
        },
        "labels": {
          "type": "array",
          "items": { "type": "string" }
        },
        "cycle": {
          "type": ["object", "null"],
          "additionalProperties": true
        },
        "module": {
          "type": ["object", "null"],
          "additionalProperties": true
        },
        "relations": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "source_comments": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "attachments_or_links": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "read_gaps": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "plane_write_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "comment_sync": { "type": "boolean", "default": true },
        "status_sync": { "type": "boolean", "default": true },
        "worklog_sync": { "type": "boolean", "default": false },
        "link_sync": { "type": "boolean", "default": false },
        "description_sync": { "type": "boolean", "default": false },
        "wiki_sync": { "type": "boolean", "default": false },
        "create_followup_items": { "type": "boolean", "default": false },
        "requires_confirmation": { "type": "boolean", "default": true },
        "notes": { "type": "string" }
      }
    },
    "plane_status_mapping": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "on_start": { "type": "string" },
        "on_all_passed": { "type": "string" },
        "on_any_failed": { "type": "string" },
        "on_blocked": { "type": "string" },
        "on_partial": { "type": "string" },
        "on_cancelled": { "type": "string" }
      }
    },
    "plane_state_workflow": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "current_state": { "type": "string" },
        "ready_state": { "type": "string", "default": "Ready to Test" },
        "in_testing_state": { "type": "string", "default": "In Testing" },
        "review_state": { "type": "string", "default": "Need Review Test Execute" },
        "issue_report_state": { "type": "string", "default": "Need Issue Report" },
        "ready_report_state": { "type": "string", "default": "Ready to Report" },
        "requires_ready_state": { "type": "boolean", "default": true },
        "approval_override": { "$ref": "#/$defs/plane_approval_override" },
        "state_read_gaps": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "plane_approval_override": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required": { "type": "boolean" },
        "approved": { "type": "boolean" },
        "approval_text": { "type": "string" },
        "approved_by": { "type": "string" },
        "approved_at": { "type": ["string", "null"] },
        "previous_state": { "type": "string" },
        "target_state": { "type": "string" },
        "reason": { "type": "string" }
      }
    },
    "notion_context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "workspace_id": { "type": "string" },
        "source_page_id": { "type": "string" },
        "source_database_id": { "type": "string" },
        "source_data_source_id": { "type": "string" },
        "source_url": { "type": "string" },
        "title": { "type": "string" },
        "source_pages": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "source_rows": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "source_comments": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "linked_refs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "output_targets": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "execution_page_id": { "type": ["string", "null"] },
            "execution_database_id": { "type": ["string", "null"] },
            "execution_data_source_id": { "type": ["string", "null"] },
            "issue_candidate_database_id": { "type": ["string", "null"] }
          }
        },
        "read_gaps": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "notion_write_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source_database_update": { "type": "boolean", "default": false },
        "execution_page_sync": { "type": "boolean", "default": false },
        "execution_database_sync": { "type": "boolean", "default": false },
        "comment_sync": { "type": "boolean", "default": false },
        "issue_candidate_sync": { "type": "boolean", "default": false },
        "requires_confirmation": { "type": "boolean", "default": true },
        "notes": { "type": "string" }
      }
    },
    "source_update_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "incremental_update": { "type": "boolean", "default": true },
        "update_after_each_case": { "type": "boolean", "default": true },
        "batch_only_when_required": { "type": "boolean", "default": true },
        "requires_confirmation": { "type": "boolean", "default": true },
        "writable_sources": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["notion", "plane", "google_sheets", "excel", "google_docs", "word", "markdown", "json", "other"]
          }
        },
        "fields": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["Test Case Status", "Actual Result", "Notes", "Evidence", "Evidence Status", "Executed At", "Blocker", "Issue Candidate Ref"]
          }
        },
        "notes": { "type": "string" }
      }
    },
    "report_output_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "create_report": { "type": "boolean", "default": false },
        "trigger": {
          "type": "string",
          "enum": ["explicit_user_request", "package_policy", "disabled_default"]
        },
        "target": {
          "type": "string",
          "enum": ["notion_page", "google_doc", "word_doc", "markdown", "spreadsheet", "plane_wiki", "none"]
        },
        "requires_confirmation": { "type": "boolean", "default": true },
        "notes": { "type": "string" }
      }
    },
    "evidence_upload_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "prefer_inline_images": { "type": "boolean", "default": true },
        "upload_when_supported": { "type": "boolean", "default": true },
        "allow_external_urls": { "type": "boolean", "default": true },
        "local_path_fallback": { "type": "boolean", "default": true },
        "requires_redaction_check": { "type": "boolean", "default": true },
        "requires_confirmation": { "type": "boolean", "default": true },
        "notes": { "type": "string" }
      }
    },
    "notion_plane_bridge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_of_truth"],
      "properties": {
        "plane_work_item_ref": { "type": ["string", "null"] },
        "notion_test_case_source_ref": { "type": ["string", "null"] },
        "notion_execution_page_ref": { "type": ["string", "null"] },
        "discovered_notion_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/discovered_notion_ref" }
        },
        "auto_notion_report": { "$ref": "#/$defs/auto_notion_report" },
        "plane_output_scope": { "$ref": "#/$defs/plane_output_scope" },
        "sync_direction": {
          "type": "string",
          "enum": ["notion_to_execution_to_plane", "plane_to_execution_to_notion", "bidirectional_rendered_views"]
        },
        "source_of_truth": { "const": "execution_result.json" },
        "cross_links": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["link_type", "source_ref", "target_ref"],
            "properties": {
              "link_type": {
                "type": "string",
                "enum": ["plane_to_notion", "notion_to_plane", "execution_result", "evidence", "other"]
              },
              "source_ref": { "type": "string" },
              "target_ref": { "type": "string" },
              "sync_status": {
                "type": "string",
                "enum": ["not_started", "synced", "partial", "failed", "skipped"]
              }
            }
          }
        },
        "idempotency_key": { "type": "string" },
        "sync_status": {
          "type": "string",
          "enum": ["not_started", "synced", "partial", "failed", "skipped"]
        },
        "sync_errors": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "discovered_notion_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "url", "classification", "confidence", "reason"],
      "properties": {
        "source": {
          "type": "string",
          "enum": ["plane_description", "plane_comment", "plane_link", "plane_attachment", "user_input", "other"]
        },
        "url": { "type": "string", "minLength": 1 },
        "classification": {
          "type": "string",
          "enum": ["test_case_source", "execution_page", "result_database", "issue_candidate_database", "unknown"]
        },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        },
        "reason": { "type": "string" },
        "notion_id": { "type": ["string", "null"] },
        "read_status": {
          "type": "string",
          "enum": ["not_started", "read", "failed", "skipped"]
        }
      }
    },
    "auto_notion_report": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "trigger": {
          "type": "string",
          "enum": ["notion_url_discovered", "explicit_user_request", "disabled_no_notion_url", "disabled_ambiguous", "disabled_unreadable"]
        },
        "source_database_update": { "type": "boolean" },
        "execution_page_sync": { "type": "boolean" },
        "requires_confirmation": { "type": "boolean" },
        "reason": { "type": "string" }
      }
    },
    "plane_output_scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "comment_mode": {
          "type": "string",
          "enum": ["summary_only", "full_when_no_notion_report"]
        },
        "description_sync": { "type": "boolean" },
        "notion_execution_page_ref": { "type": ["string", "null"] },
        "duplication_policy": {
          "type": "string",
          "enum": ["do_not_duplicate_notion_report", "allow_full_plane_report"]
        },
        "reason": { "type": "string" }
      }
    },
    "test_case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tc_id", "scenario", "steps", "expected_result", "test_case_status", "execution_mode"],
      "properties": {
        "tc_id": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "summary": { "type": "string" },
        "priority": { "type": "string", "enum": ["P0 - Critical", "P1 - High", "P2 - Medium", "P3 - Low"] },
        "pre_conditions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["step_number", "instruction", "expected_result"],
            "properties": {
              "step_number": { "type": "integer", "minimum": 1 },
              "instruction": { "type": "string", "minLength": 1 },
              "expected_result": { "type": "string", "minLength": 1 }
            }
          }
        },
        "test_data": {
          "type": "array",
          "items": { "type": "string" }
        },
        "expected_result": { "type": "string", "minLength": 1 },
        "test_case_status": {
          "type": "string",
          "enum": ["Untested", "On Progress", "Passed", "Failed", "Blocked", "Retest"]
        },
        "execution_mode": {
          "type": "string",
          "enum": ["api", "ui", "db", "hybrid", "manual_instruction"]
        },
        "dependencies": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "tags": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "custom_fields": {
          "type": "object",
          "additionalProperties": true
        },
        "source_locator": { "$ref": "#/$defs/source_locator" }
      }
    },
    "source_locator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_type"],
      "properties": {
        "source_type": {
          "type": "string",
          "enum": ["notion", "plane", "google_sheets", "excel", "google_docs", "word", "markdown", "json", "plain_text", "other"]
        },
        "source_ref": { "type": "string" },
        "page_id": { "type": "string" },
        "database_id": { "type": "string" },
        "data_source_id": { "type": "string" },
        "row_id": { "type": "string" },
        "spreadsheet_id": { "type": "string" },
        "workbook_path": { "type": "string" },
        "document_id": { "type": "string" },
        "sheet_name": { "type": "string" },
        "row_number": { "type": "integer", "minimum": 1 },
        "table_index": { "type": "integer", "minimum": 0 },
        "row_index": { "type": "integer", "minimum": 0 },
        "heading_anchor": { "type": "string" },
        "markdown_anchor": { "type": "string" },
        "json_pointer": { "type": "string" },
        "plane_ref": { "type": "string" },
        "column_map": { "type": "object", "additionalProperties": { "type": "string" } },
        "locator_confidence": { "type": "string", "enum": ["high", "medium", "low"] }
      }
    }
  }
}
