{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.qa/qa-executor/execution-package.schema.json",
  "title": "QA Executor Input Package",
  "type": "object",
  "additionalProperties": false,
  "required": ["package_id", "source_agent", "source_refs", "approval_state", "run_policy", "environment", "execution_scope", "test_cases"],
  "properties": {
    "package_id": { "type": "string", "minLength": 1 },
    "source_agent": {
      "type": "string",
      "enum": ["qa-planner", "human", "qa-executor", "external"]
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ref_type", "ref"],
        "properties": {
          "ref_type": {
            "type": "string",
            "enum": ["planning_state", "qa_executor_handoff", "manual_test_cases", "spreadsheet", "document", "json", "plain_text", "other"]
          },
          "ref": { "type": "string", "minLength": 1 },
          "summary": { "type": "string" }
        }
      }
    },
    "approval_state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["approved_by_planner", "approved_by_user", "draft_validation", "not_approved"]
        },
        "approved_by": { "type": "string" },
        "approved_at": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "run_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "selected_tc_ids", "parallel_allowed"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["initial_run", "full_regression", "failed_retest", "smoke", "targeted", "automation_validation"]
        },
        "selected_tc_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "priority_filter": {
          "type": "array",
          "items": { "type": "string", "enum": ["P0 - Critical", "P1 - High", "P2 - Medium", "P3 - Low"] }
        },
        "tag_filter": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "parallel_allowed": { "type": "boolean" },
        "notes": { "type": "string" }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "base_url": { "type": "string" },
        "build": { "type": "string" },
        "data_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "constraints": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "execution_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selected_count", "excluded_tc_ids"],
      "properties": {
        "selected_count": { "type": "integer", "minimum": 0 },
        "excluded_tc_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "selection_reason": { "type": "string" }
      }
    },
    "test_cases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/test_case" }
    },
    "custom_fields": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "test_case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tc_id", "scenario", "steps", "expected_result", "test_case_status", "execution_mode"],
      "properties": {
        "tc_id": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "summary": { "type": "string" },
        "priority": { "type": "string", "enum": ["P0 - Critical", "P1 - High", "P2 - Medium", "P3 - Low"] },
        "pre_conditions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["step_number", "instruction", "expected_result"],
            "properties": {
              "step_number": { "type": "integer", "minimum": 1 },
              "instruction": { "type": "string", "minLength": 1 },
              "expected_result": { "type": "string", "minLength": 1 }
            }
          }
        },
        "test_data": {
          "type": "array",
          "items": { "type": "string" }
        },
        "expected_result": { "type": "string", "minLength": 1 },
        "test_case_status": {
          "type": "string",
          "enum": ["Untested", "On Progress", "Passed", "Failed", "Blocked", "Retest"]
        },
        "execution_mode": {
          "type": "string",
          "enum": ["api", "ui", "db", "hybrid", "manual_instruction"]
        },
        "dependencies": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "tags": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "custom_fields": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
