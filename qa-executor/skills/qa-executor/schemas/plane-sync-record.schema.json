{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.qa/qa-executor/plane-sync-record.schema.json",
  "title": "QA Executor Plane Sync Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sync_record_id",
    "execution_id",
    "plane_work_item_id",
    "readable_identifier",
    "target_type",
    "action",
    "idempotency_key",
    "sync_status",
    "last_synced_at",
    "errors"
  ],
  "properties": {
    "sync_record_id": { "type": "string", "minLength": 1 },
    "execution_id": { "type": "string", "minLength": 1 },
    "plane_work_item_id": { "type": "string", "minLength": 1 },
    "readable_identifier": { "type": "string", "minLength": 1 },
    "target_type": {
      "type": "string",
      "enum": ["comment", "status", "worklog", "link", "description", "wiki", "followup_item"]
    },
    "target_id": { "type": ["string", "null"] },
    "action": {
      "type": "string",
      "enum": ["create", "update", "skip", "delete", "link"]
    },
    "idempotency_key": { "type": "string", "minLength": 1 },
    "content_hash": { "type": ["string", "null"] },
    "sync_status": {
      "type": "string",
      "enum": ["not_started", "synced", "partial", "failed", "skipped"]
    },
    "last_synced_at": { "type": ["string", "null"], "format": "date-time" },
    "errors": {
      "type": "array",
      "items": { "type": "string" }
    },
    "custom_fields": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
