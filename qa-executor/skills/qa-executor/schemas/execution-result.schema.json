{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.qa/qa-executor/execution-result.schema.json",
  "title": "QA Executor Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "execution_id",
    "source_agent",
    "package_id",
    "run_policy",
    "environment",
    "started_at",
    "finished_at",
    "summary",
    "results"
  ],
  "properties": {
    "execution_id": { "type": "string", "minLength": 1 },
    "source_agent": { "const": "qa-executor" },
    "package_id": { "type": "string", "minLength": 1 },
    "planning_state_ref": { "type": ["string", "null"] },
    "run_policy": { "$ref": "#/$defs/run_policy" },
    "environment": { "$ref": "#/$defs/environment" },
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": { "type": "string", "format": "date-time" },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total", "selected", "passed", "failed", "blocked", "untested", "retest"],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "selected": { "type": "integer", "minimum": 0 },
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "blocked": { "type": "integer", "minimum": 0 },
        "untested": { "type": "integer", "minimum": 0 },
        "retest": { "type": "integer", "minimum": 0 },
        "pass_rate": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
        "completion_rate": { "type": ["number", "null"], "minimum": 0, "maximum": 100 }
      }
    },
    "results": {
      "type": "array",
      "items": { "$ref": "#/$defs/test_result" }
    },
    "issue_candidates": {
      "type": "array",
      "items": { "$ref": "#/$defs/issue_candidate" }
    },
    "execution_review_history": {
      "type": "array",
      "items": { "$ref": "#/$defs/review_record" }
    },
    "qa_reporter_handoff": { "$ref": "#/$defs/reporter_handoff" },
    "qa_automation_signal": { "$ref": "#/$defs/automation_signal" },
    "plane_sync": { "$ref": "#/$defs/plane_sync" },
    "plane_state_workflow": { "$ref": "#/$defs/plane_state_workflow" },
    "notion_sync": { "$ref": "#/$defs/notion_sync" },
    "notion_plane_bridge": { "$ref": "#/$defs/notion_plane_bridge" },
    "source_updates": {
      "type": "array",
      "items": { "$ref": "#/$defs/source_update" }
    },
    "report_outputs": {
      "type": "array",
      "items": { "$ref": "#/$defs/report_output" }
    },
    "custom_fields": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "status": {
      "type": "string",
      "enum": ["Untested", "On Progress", "Passed", "Failed", "Blocked", "Retest"]
    },
    "execution_mode": {
      "type": "string",
      "enum": ["api", "ui", "db", "hybrid", "manual_instruction"]
    },
    "run_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "selected_tc_ids", "parallel_allowed"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["initial_run", "full_regression", "failed_retest", "smoke", "targeted", "automation_validation"]
        },
        "selected_tc_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "parallel_allowed": { "type": "boolean" },
        "notes": { "type": "string" }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "base_url": { "type": "string" },
        "build": { "type": "string" },
        "data_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "constraints": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "step_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step_number", "instruction", "expected_result", "actual_result", "status"],
      "properties": {
        "step_number": { "type": "integer", "minimum": 1 },
        "instruction": { "type": "string", "minLength": 1 },
        "expected_result": { "type": "string", "minLength": 1 },
        "actual_result": { "type": "string" },
        "status": { "$ref": "#/$defs/status" },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "assertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["assertion", "expected", "actual", "status"],
      "properties": {
        "assertion": { "type": "string", "minLength": 1 },
        "expected": { "type": "string" },
        "actual": { "type": "string" },
        "status": { "$ref": "#/$defs/status" }
      }
    },
    "blocker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["blocker_type", "blocker_reason"],
      "properties": {
        "blocker_type": {
          "type": "string",
          "enum": ["test_dependency", "environment", "data", "access", "credential", "endpoint", "db", "fixture", "setup"]
        },
        "blocker_reason": { "type": "string", "minLength": 1 },
        "blocked_by": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "retry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attempt", "timestamp", "reason", "outcome"],
      "properties": {
        "attempt": { "type": "integer", "minimum": 1 },
        "timestamp": { "type": "string", "format": "date-time" },
        "reason": { "type": "string", "minLength": 1 },
        "outcome": { "type": "string", "minLength": 1 },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "api_evidence": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "method": { "type": "string" },
        "url": { "type": "string" },
        "request_headers": { "type": "object", "additionalProperties": true },
        "request_body_summary": { "type": "object", "additionalProperties": true },
        "response_status": { "type": "integer" },
        "response_body_summary": { "type": "object", "additionalProperties": true }
      }
    },
    "ui_evidence": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "screenshot_refs": { "type": "array", "items": { "type": "string" } },
        "video_refs": { "type": "array", "items": { "type": "string" } },
        "trace_refs": { "type": "array", "items": { "type": "string" } },
        "observation": { "type": "string" }
      }
    },
    "db_evidence": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "query_name": { "type": "string" },
        "query_summary": { "type": "string" },
        "expected": { "type": "string" },
        "actual": { "type": "string" },
        "status": { "$ref": "#/$defs/status" }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "executor": { "type": "string" },
        "redaction_status": { "type": "string", "enum": ["passed", "gap", "not_applicable"] },
        "api": { "type": "array", "items": { "$ref": "#/$defs/api_evidence" } },
        "ui": { "$ref": "#/$defs/ui_evidence" },
        "db": { "type": "array", "items": { "$ref": "#/$defs/db_evidence" } },
        "logs": { "type": "array", "items": { "type": "string" } },
        "uploaded_assets": { "type": "array", "items": { "$ref": "#/$defs/evidence_asset" } },
        "evidence_upload_gaps": { "type": "array", "items": { "$ref": "#/$defs/evidence_upload_gap" } },
        "evidence_gaps": { "type": "array", "items": { "type": "string" } }
      }
    },
    "evidence_asset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["asset_type", "local_path", "target", "sync_status"],
      "properties": {
        "asset_type": { "type": "string", "enum": ["image", "video", "trace", "log", "other"] },
        "local_path": { "type": "string" },
        "target": { "type": "string", "enum": ["notion", "plane", "google_sheets", "excel", "google_docs", "word", "markdown", "json", "other"] },
        "remote_ref": { "type": ["string", "null"] },
        "field": { "type": "string" },
        "redaction_status": { "type": "string", "enum": ["passed", "gap", "not_applicable"] },
        "sync_status": { "type": "string", "enum": ["not_started", "synced", "partial", "failed", "skipped"] }
      }
    },
    "evidence_upload_gap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "local_path", "reason"],
      "properties": {
        "target": { "type": "string", "enum": ["notion", "plane", "google_sheets", "excel", "google_docs", "word", "markdown", "json", "other"] },
        "local_path": { "type": "string" },
        "intended_field": { "type": "string" },
        "reason": { "type": "string" }
      }
    },
    "issue_candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "issue_candidate_id",
        "tc_id",
        "severity_suggestion",
        "title",
        "summary",
        "reproduction_steps",
        "expected_result",
        "actual_result",
        "evidence_refs",
        "suggested_owner",
        "requires_human_review"
      ],
      "properties": {
        "issue_candidate_id": { "type": "string", "minLength": 1 },
        "tc_id": { "type": "string", "minLength": 1 },
        "severity_suggestion": { "type": "string", "enum": ["Critical", "High", "Medium", "Low"] },
        "title": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "reproduction_steps": { "type": "array", "items": { "type": "string" } },
        "expected_result": { "type": "string", "minLength": 1 },
        "actual_result": { "type": "string", "minLength": 1 },
        "evidence_refs": { "type": "array", "items": { "type": "string" } },
        "suggested_owner": { "type": "string", "minLength": 1 },
        "requires_human_review": { "const": true },
        "custom_fields": { "type": "object", "additionalProperties": true }
      }
    },
    "automation_update_signal": {
      "type": ["object", "null"],
      "additionalProperties": true,
      "properties": {
        "signal_type": {
          "type": "string",
          "enum": ["flaky_technical_failure", "selector_gap", "api_gap", "data_gap", "script_update_candidate"]
        },
        "reason": { "type": "string" }
      }
    },
    "test_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tc_id",
        "scenario",
        "selected",
        "execution_mode",
        "test_case_status",
        "actual_result",
        "started_at",
        "finished_at",
        "duration_ms",
        "steps",
        "assertions",
        "retries",
        "evidence"
      ],
      "properties": {
        "tc_id": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "selected": { "type": "boolean" },
        "execution_mode": { "$ref": "#/$defs/execution_mode" },
        "test_case_status": { "$ref": "#/$defs/status" },
        "expected_result": { "type": "string" },
        "actual_result": { "type": "string" },
        "started_at": { "type": ["string", "null"], "format": "date-time" },
        "finished_at": { "type": ["string", "null"], "format": "date-time" },
        "duration_ms": { "type": ["integer", "null"], "minimum": 0 },
        "steps": { "type": "array", "items": { "$ref": "#/$defs/step_result" } },
        "assertions": { "type": "array", "items": { "$ref": "#/$defs/assertion" } },
        "blocker": { "anyOf": [{ "$ref": "#/$defs/blocker" }, { "type": "null" }] },
        "retries": { "type": "array", "items": { "$ref": "#/$defs/retry" } },
        "evidence": { "$ref": "#/$defs/evidence" },
        "issue_candidate": { "anyOf": [{ "$ref": "#/$defs/issue_candidate" }, { "type": "null" }] },
        "automation_update_signal": { "$ref": "#/$defs/automation_update_signal" },
        "notes": { "type": "string" },
        "source_locator": { "$ref": "#/$defs/source_locator" },
        "custom_fields": { "type": "object", "additionalProperties": true }
      },
      "allOf": [
        {
          "if": { "properties": { "test_case_status": { "const": "Failed" } }, "required": ["test_case_status"] },
          "then": {
            "required": ["expected_result", "issue_candidate"],
            "properties": {
              "expected_result": { "type": "string", "minLength": 1 },
              "actual_result": { "type": "string", "minLength": 1 },
              "issue_candidate": { "$ref": "#/$defs/issue_candidate" }
            }
          }
        },
        {
          "if": { "properties": { "test_case_status": { "const": "Blocked" } }, "required": ["test_case_status"] },
          "then": {
            "required": ["blocker", "issue_candidate"],
            "properties": {
              "blocker": { "$ref": "#/$defs/blocker" },
              "issue_candidate": { "$ref": "#/$defs/issue_candidate" }
            }
          }
        }
      ]
    },
    "review_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["review_status", "reviewer", "reviewed_at"],
      "properties": {
        "review_status": { "type": "string", "enum": ["OK", "NOK"] },
        "reviewer": { "type": "string", "minLength": 1 },
        "reviewed_at": { "type": "string", "format": "date-time" },
        "note": { "type": "string" }
      }
    },
    "source_update": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tc_id", "source_locator", "fields", "sync_status"],
      "properties": {
        "tc_id": { "type": "string", "minLength": 1 },
        "source_locator": { "$ref": "#/$defs/source_locator" },
        "fields": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "number", "boolean", "null"]
          }
        },
        "evidence_assets": { "type": "array", "items": { "$ref": "#/$defs/evidence_asset" } },
        "sync_status": { "type": "string", "enum": ["not_started", "synced", "partial", "failed", "skipped"] },
        "sync_errors": { "type": "array", "items": { "type": "string" } }
      }
    },
    "report_output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "created", "reason"],
      "properties": {
        "target": { "type": "string", "enum": ["notion_page", "google_doc", "word_doc", "markdown", "spreadsheet", "plane_wiki", "none"] },
        "created": { "type": "boolean" },
        "ref": { "type": ["string", "null"] },
        "reason": { "type": "string" }
      }
    },
    "source_locator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_type"],
      "properties": {
        "source_type": { "type": "string", "enum": ["notion", "plane", "google_sheets", "excel", "google_docs", "word", "markdown", "json", "plain_text", "other"] },
        "source_ref": { "type": "string" },
        "page_id": { "type": "string" },
        "database_id": { "type": "string" },
        "data_source_id": { "type": "string" },
        "row_id": { "type": "string" },
        "spreadsheet_id": { "type": "string" },
        "workbook_path": { "type": "string" },
        "document_id": { "type": "string" },
        "sheet_name": { "type": "string" },
        "row_number": { "type": "integer", "minimum": 1 },
        "table_index": { "type": "integer", "minimum": 0 },
        "row_index": { "type": "integer", "minimum": 0 },
        "heading_anchor": { "type": "string" },
        "markdown_anchor": { "type": "string" },
        "json_pointer": { "type": "string" },
        "plane_ref": { "type": "string" },
        "column_map": { "type": "object", "additionalProperties": { "type": "string" } },
        "locator_confidence": { "type": "string", "enum": ["high", "medium", "low"] }
      }
    },
    "reporter_handoff": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "source_agent": { "const": "qa-executor" },
        "execution_result_ref": { "type": "string" },
        "approval_status": { "type": "string", "enum": ["OK", "NOK", "pending"] }
      }
    },
    "automation_signal": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "source_agent": { "const": "qa-executor" },
        "execution_result_ref": { "type": "string" },
        "selector_gaps": { "type": "array" },
        "api_gaps": { "type": "array" },
        "data_gaps": { "type": "array" },
        "flaky_technical_failures": { "type": "array" },
        "update_candidates": { "type": "array" }
      }
    },
    "plane_sync": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source_work_item": { "type": "string" },
        "managed_comment_id": { "type": ["string", "null"] },
        "wiki_page_id": { "type": ["string", "null"] },
        "worklog_id": { "type": ["string", "null"] },
        "description_summary_status": {
          "type": "string",
          "enum": ["not_started", "synced", "partial", "failed", "skipped"]
        },
        "description_summary_gap": { "type": "string" },
        "status_before": { "type": ["string", "null"] },
        "status_after": { "type": ["string", "null"] },
        "status_transition_reason": { "type": "string" },
        "linked_refs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["ref_type", "ref"],
            "properties": {
              "ref_type": {
                "type": "string",
                "enum": ["evidence", "execution_result", "issue_candidate", "reporter_handoff", "automation_signal", "followup_item", "notion_execution_page", "other"]
              },
              "ref": { "type": "string", "minLength": 1 },
              "target_id": { "type": "string" },
              "sync_status": {
                "type": "string",
                "enum": ["not_started", "synced", "partial", "failed", "skipped"]
              }
            }
          }
        },
        "sync_status": {
          "type": "string",
          "enum": ["not_started", "synced", "partial", "failed", "skipped"]
        },
        "sync_errors": {
          "type": "array",
          "items": { "type": "string" }
        },
        "idempotency_key": { "type": "string" },
        "status_transition_gap": { "type": "string" }
      }
    },
    "plane_state_workflow": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "current_state_before_execution": { "type": ["string", "null"] },
        "started_from_ready_to_test": { "type": "boolean" },
        "approval_override": { "$ref": "#/$defs/plane_approval_override" },
        "transitions": {
          "type": "array",
          "items": { "$ref": "#/$defs/plane_state_transition" }
        },
        "final_review_state": {
          "type": ["string", "null"],
          "enum": ["Need Review Test Execute", "Need Issue Report", "Ready to Report", "In Testing", null]
        },
        "state_gaps": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "plane_approval_override": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required": { "type": "boolean" },
        "approved": { "type": "boolean" },
        "approval_text": { "type": "string" },
        "approved_by": { "type": "string" },
        "approved_at": { "type": ["string", "null"] },
        "previous_state": { "type": "string" },
        "target_state": { "type": "string" },
        "reason": { "type": "string" }
      }
    },
    "plane_state_transition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from_state", "to_state", "trigger", "sync_status"],
      "properties": {
        "from_state": { "type": ["string", "null"] },
        "to_state": { "type": "string" },
        "trigger": {
          "type": "string",
          "enum": ["start_execution", "execution_finished", "review_ok_with_issue", "review_ok_no_issue", "review_nok", "approval_override", "cancelled", "other"]
        },
        "transitioned_at": { "type": ["string", "null"] },
        "sync_status": {
          "type": "string",
          "enum": ["not_started", "synced", "partial", "failed", "skipped"]
        },
        "reason": { "type": "string" }
      }
    },
    "notion_sync": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source_page_id": { "type": ["string", "null"] },
        "source_database_id": { "type": ["string", "null"] },
        "source_data_source_id": { "type": ["string", "null"] },
        "source_url": { "type": ["string", "null"] },
        "execution_page_id": { "type": ["string", "null"] },
        "execution_database_id": { "type": ["string", "null"] },
        "execution_data_source_id": { "type": ["string", "null"] },
        "managed_comment_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "updated_source_row_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "result_row_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "issue_candidate_page_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "linked_refs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["ref_type", "ref"],
            "properties": {
              "ref_type": {
                "type": "string",
                "enum": ["evidence", "execution_result", "issue_candidate", "reporter_handoff", "automation_signal", "notion_page", "notion_database", "other"]
              },
              "ref": { "type": "string", "minLength": 1 },
              "target_id": { "type": "string" },
              "sync_status": {
                "type": "string",
                "enum": ["not_started", "synced", "partial", "failed", "skipped"]
              }
            }
          }
        },
        "sync_status": {
          "type": "string",
          "enum": ["not_started", "synced", "partial", "failed", "skipped"]
        },
        "sync_errors": {
          "type": "array",
          "items": { "type": "string" }
        },
        "idempotency_key": { "type": "string" }
      }
    },
    "notion_plane_bridge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_of_truth", "sync_status"],
      "properties": {
        "plane_work_item_ref": { "type": ["string", "null"] },
        "notion_test_case_source_ref": { "type": ["string", "null"] },
        "notion_execution_page_ref": { "type": ["string", "null"] },
        "discovered_notion_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/discovered_notion_ref" }
        },
        "auto_notion_report": { "$ref": "#/$defs/auto_notion_report" },
        "plane_output_scope": { "$ref": "#/$defs/plane_output_scope" },
        "sync_direction": {
          "type": "string",
          "enum": ["notion_to_execution_to_plane", "plane_to_execution_to_notion", "bidirectional_rendered_views"]
        },
        "source_of_truth": { "const": "execution_result.json" },
        "cross_links": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["link_type", "source_ref", "target_ref", "sync_status"],
            "properties": {
              "link_type": {
                "type": "string",
                "enum": ["plane_to_notion", "notion_to_plane", "execution_result", "evidence", "other"]
              },
              "source_ref": { "type": "string" },
              "target_ref": { "type": "string" },
              "sync_status": {
                "type": "string",
                "enum": ["not_started", "synced", "partial", "failed", "skipped"]
              }
            }
          }
        },
        "idempotency_key": { "type": "string" },
        "sync_status": {
          "type": "string",
          "enum": ["not_started", "synced", "partial", "failed", "skipped"]
        },
        "sync_errors": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "discovered_notion_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "url", "classification", "confidence", "reason"],
      "properties": {
        "source": {
          "type": "string",
          "enum": ["plane_description", "plane_comment", "plane_link", "plane_attachment", "user_input", "other"]
        },
        "url": { "type": "string", "minLength": 1 },
        "classification": {
          "type": "string",
          "enum": ["test_case_source", "execution_page", "result_database", "issue_candidate_database", "unknown"]
        },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        },
        "reason": { "type": "string" },
        "notion_id": { "type": ["string", "null"] },
        "read_status": {
          "type": "string",
          "enum": ["not_started", "read", "failed", "skipped"]
        }
      }
    },
    "auto_notion_report": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "trigger": {
          "type": "string",
          "enum": ["notion_url_discovered", "explicit_user_request", "disabled_no_notion_url", "disabled_ambiguous", "disabled_unreadable"]
        },
        "source_database_update": { "type": "boolean" },
        "execution_page_sync": { "type": "boolean" },
        "requires_confirmation": { "type": "boolean" },
        "reason": { "type": "string" }
      }
    },
    "plane_output_scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "comment_mode": {
          "type": "string",
          "enum": ["summary_only", "full_when_no_notion_report"]
        },
        "description_sync": { "type": "boolean" },
        "notion_execution_page_ref": { "type": ["string", "null"] },
        "duplication_policy": {
          "type": "string",
          "enum": ["do_not_duplicate_notion_report", "allow_full_plane_report"]
        },
        "reason": { "type": "string" }
      }
    }
  }
}
